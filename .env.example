# Polymarket Market Maker Bot - Environment Variables
# Copy to .env and fill in your values

# Required: Your wallet's private key (EOA - see SETUP_CHECKLIST.md for how to get it)
PRIVATE_KEY=0x...

# Optional: Funder address (required for Magic/email wallets; use your address for EOA)
FUNDER=

# Optional: Signature type - 0 for EOA (MetaMask, hardware wallet), 1 for Magic/email
SIGNATURE_TYPE=0

# Optional: Dry run mode - set to "true" to skip placing real orders
DRY_RUN=true

# Optional: Capital limits (defaults: $100 total, $20 per market)
# ORDER_SIZE=20
# MAX_POSITION_PER_MARKET=20
# MAX_TOTAL_CAPITAL=100
# MAX_ACTIVE_MARKETS=5
